# Pin LF line endings so byte-equality checks like
# tests/test_extended_structures.py::test_synth_samples_in_sync (which
# compares the committed sample bytes against the generator's flat
# rendering) pass on Windows runners. Without this, actions/checkout
# would (per the Git default on Windows) hand pytest CRLF-converted
# copies of the committed LF files, and the round-trip would diff
# every line.

# Python source — uniformly LF in the repo, keep it that way.
*.py text eol=lf

# Carthorse-authored XML fixtures (generated by tools/build_synth_samples.py).
# The vendored ZF24 / mustangproject samples next to them are intentionally
# left untouched — they ship from upstream with CRLF and the schematron /
# XSD consumers don't care, so re-normalising them would only churn diffs.
tests/samples/EXTENDED_synth_*.xml text eol=lf

# Markdown, TOML, YAML, plain text — consistent LF.
*.md text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
Makefile text eol=lf
